---
layout: layout-base.njk
title: Publish Article
permalink: /publish/index.html
---

<section class="hero">
  <h1>Publish Article</h1>
  <p>Standalone article publishing page (outside /manage).</p>
</section>

<section class="card" style="margin-bottom:14px;">
  <div class="pill-row">
    <button class="btn" id="pubTabNew" type="button">New Article</button>
    <button class="btn" id="pubTabManage" type="button">Edit / Delete</button>
  </div>
</section>

<section id="loadedBanner" class="card" style="display:none;margin-bottom:14px;">
  <div class="meta"><strong>Loaded for editing:</strong> <span id="loadedRefText">—</span></div>
</section>

<section class="card" id="newArticleCard">
  <label style="display:block;margin-bottom:10px;">
    <div class="meta" style="margin-bottom:4px;">Studio API Token</div>
    <input id="pubToken" type="password" style="width:100%;background:#00000040;color:#fff;border:1px solid #ffffff2e;border-radius:10px;padding:10px;" />
  </label>

  <div class="archive-control-grid">
    <label><div class="meta">Title</div><input id="pubTitle" type="text" /></label>
    <label><div class="meta">Date</div><input id="pubDate" type="date" /></label>
    <label><div class="meta">Image URL</div><input id="pubImage" type="text" placeholder="/assets/uploads/articles/..." /></label>
    <label><div class="meta">Article Image Upload</div><input id="pubImageFile" type="file" accept="image/*" /></label>
  </div>

  <div class="pill-row" style="margin-top:10px;">
    <button class="btn" id="pubUploadImage">Upload image</button>
  </div>

  <label style="display:block;margin-top:10px;"><div class="meta">Brief description</div><textarea id="pubDesc" style="width:100%;min-height:80px;background:#00000040;color:#fff;border:1px solid #ffffff2e;border-radius:10px;padding:10px;"></textarea></label>

  <label style="display:block;margin-top:10px;">
    <div class="meta" style="margin-bottom:6px;">Tags</div>
    <div class="pill-row" style="margin-bottom:8px;">
      <button class="btn" id="loadTagsBtn" type="button">Load existing tags</button>
      <span class="meta">Select tags to include with this article.</span>
    </div>
    <div id="tagPicker" class="pill-row" style="flex-wrap:wrap;gap:8px;"></div>
    <input id="customTags" type="text" placeholder="Optional custom tags (comma-separated)" style="margin-top:8px;width:100%;background:#00000040;color:#fff;border:1px solid #ffffff2e;border-radius:10px;padding:10px;" />
  </label>
  <label style="display:block;margin-top:10px;" class="meta"><input id="pubDraft" type="checkbox" /> Save as draft (not public)</label>
  <label style="display:block;margin-top:10px;"><div class="meta">Article body (Markdown)</div><textarea id="pubBody" style="width:100%;min-height:240px;background:#00000040;color:#fff;border:1px solid #ffffff2e;border-radius:10px;padding:10px;"></textarea></label>

  <div class="pill-row" style="margin-top:10px;">
    <button class="btn" id="pubArticle">Publish article</button>
    <button class="btn" id="updateArticle" type="button">Update loaded article</button>
    <input type="hidden" id="editRef" />
  </div>

  <div id="pubOut" class="meta" style="margin-top:10px;white-space:pre-wrap;background:#00000030;border:1px solid #ffffff22;border-radius:10px;padding:10px;min-height:48px;">Ready.</div>
</section>

<section class="card" id="manageArticleCard" style="margin-top:14px;">
  <h2>Edit / Remove Article</h2>
  <p class="meta">Select an article and remove it (will rebuild site).</p>
  <div class="pill-row">
    <select id="delArticleSelect" style="flex:1;min-width:260px;background:#00000040;color:#fff;border:1px solid #ffffff2e;border-radius:10px;padding:10px;"></select>
    <button class="btn" id="refreshArticles">Refresh list</button>
    <button class="btn" id="loadArticleBtn">Load into editor</button>
    <button class="btn" id="deleteArticleBtn">Delete article</button>
  </div>
  <div id="delOut" class="meta" style="margin-top:10px;white-space:pre-wrap;background:#00000030;border:1px solid #ffffff22;border-radius:10px;padding:10px;min-height:38px;">Ready.</div>
</section>

<script>
(() => {
  const byId = (id) => document.getElementById(id);
  const out = byId('pubOut');
  const token = () => (byId('pubToken').value || '').trim();

  const newCard = byId('newArticleCard');
  const manageCard = byId('manageArticleCard');
  const tabNew = byId('pubTabNew');
  const tabManage = byId('pubTabManage');
  const loadedBanner = byId('loadedBanner');
  const loadedRefText = byId('loadedRefText');

  function setTab(which) {
    const isNew = which === 'new';
    if (newCard) newCard.style.display = isNew ? '' : 'none';
    if (manageCard) manageCard.style.display = isNew ? 'none' : '';
    if (tabNew) tabNew.classList.toggle('active', isNew);
    if (tabManage) tabManage.classList.toggle('active', !isNew);
  }

  const d = new Date();
  byId('pubDate').value = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;

  const delOut = byId('delOut');

  async function api(path, opts={}) {
    const t = token();
    if (!t) throw new Error('Token required.');
    const res = await fetch(path, {
      ...opts,
      headers: {
        ...(opts.headers || {}),
        'x-studio-token': t,
      }
    });
    const data = await res.json();
    if (!res.ok || !data.ok) throw new Error(data.error || `Request failed (${res.status})`);
    return data;
  }

  async function loadArticleList() {
    const sel = byId('delArticleSelect');
    if (!sel) return;
    sel.innerHTML = '';
    const data = await api('/publish/api/list-articles');
    const items = Array.isArray(data.items) ? data.items : [];
    if (!items.length) {
      const o = document.createElement('option');
      o.value = '';
      o.textContent = 'No articles found';
      sel.appendChild(o);
      return;
    }
    for (const it of items) {
      const o = document.createElement('option');
      o.value = it.ref;
      o.textContent = `${it.name} (${it.kind})`;
      sel.appendChild(o);
    }
  }

  function selectedTags() {
    const tags = [];
    document.querySelectorAll('input[name="pubTag"]:checked').forEach((cb) => tags.push(cb.value));
    const custom = (byId('customTags')?.value || '').split(',').map((t) => t.trim()).filter(Boolean);
    return [...new Set([...tags, ...custom])];
  }

  function renderTagPicker(tags=[]) {
    const wrap = byId('tagPicker');
    if (!wrap) return;
    wrap.innerHTML = '';
    tags.forEach((tag) => {
      const id = `tag-${tag}`;
      const label = document.createElement('label');
      label.className = 'pill';
      label.style.cursor = 'pointer';
      label.innerHTML = `<input type="checkbox" name="pubTag" value="${tag}" id="${id}" style="margin-right:6px;"/> ${tag}`;
      wrap.appendChild(label);
    });
  }

  async function loadTags() {
    const data = await api('/publish/api/list-tags');
    const tags = Array.isArray(data.tags) ? data.tags : [];
    renderTagPicker(tags);
    return tags;
  }

  async function uploadImage(file, folder, nameHint) {
    const t = token();
    if (!t) throw new Error('Token required.');
    if (!file) throw new Error('No file selected.');

    const fd = new FormData();
    fd.append('image', file);
    fd.append('folder', folder);
    fd.append('name', nameHint || 'upload');
    fd.append('rebuild', 'true');

    const res = await fetch('/publish/api/upload-image', {
      method: 'POST',
      headers: { 'x-studio-token': t },
      body: fd
    });
    const data = await res.json();
    if (!res.ok || !data.ok) throw new Error(data.error || `Upload failed (${res.status})`);
    return data.url;
  }

  byId('pubUploadImage').addEventListener('click', async () => {
    try {
      const file = byId('pubImageFile').files[0];
      const hint = byId('pubTitle').value || 'article-image';
      const url = await uploadImage(file, 'articles', hint);
      byId('pubImage').value = url;
      out.textContent = `Image uploaded: ${url}`;
    } catch (e) {
      out.textContent = `Image upload error: ${e.message}`;
    }
  });

  byId('pubArticle').addEventListener('click', async () => {
    try {
      const t = token();
      if (!t) throw new Error('Token required.');

      const payload = {
        title: byId('pubTitle').value.trim(),
        date: byId('pubDate').value.trim(),
        image: byId('pubImage').value.trim(),
        description: byId('pubDesc').value.trim(),
        body: byId('pubBody').value.trim(),
        tags: selectedTags(),
        draft: !!byId('pubDraft')?.checked,
      };

      const res = await fetch('/publish/api/save-article', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'x-studio-token': t },
        body: JSON.stringify(payload)
      });
      const data = await res.json();
      if (!res.ok || !data.ok) throw new Error(data.error || `Publish failed (${res.status})`);

      byId('editRef').value = '';
      if (loadedBanner) loadedBanner.style.display = 'none';
      if (loadedRefText) loadedRefText.textContent = '—';
      out.textContent = data.draft ? `Saved draft ✅ ${data.filename}` : `Published ✅ ${data.filename} → ${data.path}`;
    } catch (e) {
      out.textContent = `Publish error: ${e.message}`;
    }
  });

  byId('loadTagsBtn').addEventListener('click', async () => {
    try {
      const tags = await loadTags();
      out.textContent = tags.length ? `Loaded ${tags.length} tags.` : 'No existing tags found yet.';
    } catch (e) {
      out.textContent = `Tag load error: ${e.message}`;
    }
  });

  byId('refreshArticles').addEventListener('click', async () => {
    try {
      await loadArticleList();
      delOut.textContent = 'Article list refreshed.';
    } catch (e) {
      delOut.textContent = `Refresh error: ${e.message}`;
    }
  });


  byId('loadArticleBtn').addEventListener('click', async () => {
    try {
      const ref = byId('delArticleSelect').value;
      if (!ref) throw new Error('Select an article first.');
      const data = await api(`/publish/api/get-article?ref=${encodeURIComponent(ref)}`);
      byId('editRef').value = data.ref || ref;
      byId('pubTitle').value = data.title || '';
      byId('pubDate').value = (data.date || '').slice(0,10);
      byId('pubImage').value = data.image || '';
      byId('pubDesc').value = data.description || '';
      byId('pubBody').value = data.body || '';

      const tags = Array.isArray(data.tags) ? data.tags.filter(t => t !== 'articles') : [];
      const known = new Set(Array.from(document.querySelectorAll('input[name="pubTag"]')).map(cb => cb.value));
      const knownSelected = tags.filter(t => known.has(t));
      const custom = tags.filter(t => !known.has(t));
      document.querySelectorAll('input[name="pubTag"]').forEach(cb => { cb.checked = knownSelected.includes(cb.value); });
      byId('customTags').value = custom.join(', ');

      if (loadedBanner) loadedBanner.style.display = '';
      if (loadedRefText) loadedRefText.textContent = ref;
      setTab('new');
      out.textContent = `Loaded article: ${ref}`;
    } catch (e) {
      out.textContent = `Load error: ${e.message}`;
    }
  });

  byId('updateArticle').addEventListener('click', async () => {
    try {
      const ref = byId('editRef').value || byId('delArticleSelect').value;
      if (!ref) throw new Error('Load/select an article first.');
      const payload = {
        ref,
        title: byId('pubTitle').value.trim(),
        date: byId('pubDate').value.trim(),
        image: byId('pubImage').value.trim(),
        description: byId('pubDesc').value.trim(),
        body: byId('pubBody').value.trim(),
        tags: selectedTags(),
        draft: !!byId('pubDraft')?.checked,
      };
      const data = await api('/publish/api/update-article', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      if (loadedBanner) loadedBanner.style.display = '';
      if (loadedRefText) loadedRefText.textContent = data.updated || ref;
      out.textContent = `Updated ✅ ${data.updated}`;
      await loadArticleList();
    } catch (e) {
      out.textContent = `Update error: ${e.message}`;
    }
  });

  byId('deleteArticleBtn').addEventListener('click', async () => {
    try {
      const ref = byId('delArticleSelect').value;
      if (!ref) throw new Error('Select an article first.');
      const ok = confirm(`Delete article: ${ref}?`);
      if (!ok) return;

      const data = await api('/publish/api/delete-article', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ref })
      });

      delOut.textContent = `Deleted ✅ ${data.deleted}`;
      await loadArticleList();
    } catch (e) {
      delOut.textContent = `Delete error: ${e.message}`;
    }
  });

  tabNew?.addEventListener('click', () => setTab('new'));
  tabManage?.addEventListener('click', () => setTab('manage'));
  setTab('new');

  loadTags().catch(() => {});

  loadArticleList().catch((e) => {
    if (delOut) delOut.textContent = `List load error: ${e.message}`;
  });
})();
</script>
