---
layout: layout-base.njk
pagination:
  data: collections.tagList
  size: 1
  alias: tag
permalink: /tags/{{ tag | url }}/index.html
title: "Tag"
---

<section class="hero">
  <h1>Tag: {{ tag }}</h1>
  <p>Posts filed under “{{ tag }}”.</p>
</section>

<section class="card" style="margin-top:18px;">
  <div class="article-list">
    {% set posts = collections[tag] | reverse %}
    {% for post in posts %}
      <a class="article" href="{{ post.url }}">
        <div class="kicker">{{ post.date | readableDate }}</div>
        <div class="name">{{ post.data.title }}</div>
        {% if post.data.description %}
          <div class="blurb">{{ post.data.description }}</div>
        {% endif %}
      </a>
    {% endfor %}
  </div>
</section>
