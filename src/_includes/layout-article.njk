---
layout: layout-base.njk
---

<section class="hero">
  <h1>{{ title }}</h1>
  <p class="meta">{{ date | readableDate }}</p>
  {% if description %}
    <p style="margin-top:10px; max-width:72ch;">{{ description }}</p>
  {% endif %}
</section>

{% if image %}
  <section class="card" style="margin-top:18px; padding:0; overflow:hidden;">
    <img src="{{ image }}" alt="{{ title }}" style="display:block; width:100%; height:auto;" />
  </section>
{% endif %}

<article class="card" style="margin-top:18px; line-height:1.6;">
  {{ content | safe }}
</article>


<section class="card" style="margin-top:14px;">
  <div class="pill-row" style="align-items:center;gap:10px;">
    <button class="btn" id="articleLikeBtn" type="button">❤ Like</button>
    <span class="meta" id="articleLikeCount">Likes: —</span>
    <span class="meta" id="articleLikeNote" aria-live="polite"></span>
  </div>
</section>

<script>
(() => {
  const btn = document.getElementById('articleLikeBtn');
  const out = document.getElementById('articleLikeCount');
  const note = document.getElementById('articleLikeNote');
  const m = /^\/articles\/([^/]+)\/?(?:$|[?#])/.exec(window.location.pathname);
  const slug = m ? m[1] : '';
  if (!btn || !out) return;
  if (!slug) {
    out.textContent = 'Likes: unavailable';
    if (note) note.textContent = '';
    btn.disabled = true;
    return;
  }

  const sessionKey = `rp-liked:${slug}`;
  const hasLikedThisSession = () => {
    try { return !!window.sessionStorage && sessionStorage.getItem(sessionKey) === '1'; }
    catch (_) { return false; }
  };
  const markLikedThisSession = () => {
    try { if (window.sessionStorage) sessionStorage.setItem(sessionKey, '1'); }
    catch (_) {}
  };

  async function getLikes() {
    const res = await fetch(`/likes/api/${slug}`);
    const data = await res.json();
    if (data?.ok) out.textContent = `Likes: ${data.likes}`;
    else out.textContent = 'Likes: error';
  }

  if (hasLikedThisSession()) {
    btn.disabled = true;
    if (note) note.textContent = 'You already liked this in this session.';
  }

  btn.addEventListener('click', async () => {
    btn.disabled = true;
    const prev = out.textContent;
    out.textContent = 'Likes: updating…';
    if (note) note.textContent = '';

    try {
      const res = await fetch(`/likes/api/${slug}/like`, { method: 'POST' });
      const data = await res.json();
      if (data?.ok) {
        out.textContent = `Likes: ${data.likes}`;
        markLikedThisSession();
        btn.disabled = true;
        if (note) note.textContent = 'Thanks for the like!';
      } else {
        out.textContent = prev;
        btn.disabled = false;
        if (note) note.textContent = 'Could not submit like. Try again.';
      }
    } catch (_e) {
      out.textContent = prev;
      btn.disabled = false;
      if (note) note.textContent = 'Could not submit like. Try again.';
    }
  });

  getLikes().catch(() => {
    out.textContent = 'Likes: error';
  });
})();
</script>


{% if tags and tags.length %}
<section class="card" style="margin-top:14px;">
  <div class="meta">Filed under:</div>
  <div class="pill-row" style="margin-top:8px;">
    {% for t in tags %}
      {% if t != 'articles' %}
        <a class="pill" href="/tags/{{ t | url }}/">{{ t }}</a>
      {% endif %}
    {% endfor %}
  </div>
</section>
{% endif %}

<section class="card" style="margin-top:14px;">
  <a href="/articles/">← Back to articles</a>
</section>
