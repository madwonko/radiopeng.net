<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ title or "RadioPeng" }}</title>

  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" type="image/png" href="/favicon.png">

  <link rel="stylesheet" href="/assets/style.css" />
  <link rel="alternate" type="application/rss+xml" title="RadioPeng RSS" href="/feed.xml" />
</head>

<body>
  <div class="page">

    <!-- TOP HEADER -->
    <header class="topbar">
      <div class="brandrow">
        <a href="/" class="logo-link" aria-label="RadioPeng home">
          <img src="/assets/radiopeng-logo.png" alt="RadioPeng" class="site-logo">
        </a>

        <!-- <div class="header-player">
          <button id="playToggle" class="play-btn" type="button">▶︎</button>
          <span id="headerNowPlaying" class="header-np">loading…</span>
        </div> -->
      </div>
    </header>

    <!-- PORTAL LAYOUT -->
    <div class="portal">

      <!-- SIDEBAR -->
      <aside class="sidebar">

        <section class="sidebox schedulebox">
          <h3>On Air Now</h3>
          <a href="/schedule/" class="side-link" id="openSchedule" data-no-swup>
            Full Schedule (table)
          </a>
        </section>

        {% if upNext %}
        <section class="sidebox up-next">
          <h3>Up Next</h3>
          <div class="up-next-show">
            <div class="show-title">{{ upNext.show }}</div>
            <div class="show-meta">{{ upNext.day }} · {{ upNext.start }}–{{ upNext.end }}</div>
            {% if upNext.dj %}
              <div class="show-dj">with {{ upNext.dj }}</div>
            {% endif %}
          </div>
        </section>
        {% endif %}

        <!-- BROWSE -->
        <section class="sidebox">
          <h3>Browse</h3>
          <a class="side-link" href="/articles/">Latest Articles</a>
          <a class="side-link" href="/tags/">Tags</a>
          <a class="side-link" href="/feed.xml">RSS Feed</a>
          <a class="side-link" href="/programs/">Shows</a>
          <a class="side-link" href="/djs/">DJs</a>
          <a class="side-link" href="/archive/">Archive</a>

          <a class="side-link" href="/shows.xml">Show RSS</a>
        </section>

        <!-- SUPPORT -->
        <section class="sidebox supportbox">
          <h3>Support RadioPeng</h3>

          <p class="meta">
            RadioPeng is a small, listener-supported station broadcasting
            strange, beautiful, occasionally unwise music.
            RadioPeng is independent and listener-supported.
            If the signal matters to you, help keep it on the air.
          </p>

          <a class="side-link" href="/support/">
            Donate
          </a>

          <a class="side-link" href="/support/#monthly">
            Become a sustaining listener
          </a>
        </section>

      </aside>

      <!-- MAIN CONTENT -->
      <main class="main" id="swup">
        <div class="now-playing-ribbon">
          <div class="ticker">
            <span id="nowPlayingText">▶ Now Playing: loading…</span>
          </div>
        </div>

        {# NOTE: your banner block had a stray {% endif %} when commented.
           Keeping your original intent but removing the orphan endif. #}

        {% if page.url == "/" %}
          {% include "home-excerpt.njk" %}
        {% endif %}

        {% include "upcoming-shows.njk" %}

        {{ content | safe }}
      </main>

    </div>

    <!-- FOOTER -->
    <footer class="site-footer" id="siteFooter">
      <div class="footer-inner">

        <div class="footer-left">
          <span class="footer-brand">RadioPeng</span>
          <span class="footer-tagline">Independent nocturnal transmissions, Broadcasting from somewhere between the West Coast and West End</span>
        </div>

        <nav class="footer-right" aria-label="Footer">
          <a href="/schedule/">Schedule</a>
          <a href="/programs/">Shows</a>
          <a href="/djs/">DJs</a>
          <a href="/archive/">Archive</a>
          <a href="/articles/">Articles</a>
          <a href="/manifesto/">Manifesto</a>
          <a href="/support/">Support</a>
          <a href="/feed.xml">RSS</a>
        </nav>

      </div>
    </footer>

  </div>

  <!-- PLAYER BAR (persistent UI, outside #swup so it survives navigation) -->
  <div class="playerbar">
    <div class="player-inner">
      <button class="btn" id="playBtn" type="button">Play</button>

      <div class="now">
        <img id="artImg" class="art" alt="Cover art" src="/assets/cover-fallback.png" />

        <div class="nowtext">
          <div class="label">
            Now Playing
            <span id="npShow" class="npShow hidden"></span>
          </div>

          <div class="value" id="npText">Loading…</div>

          <div class="meta" style="margin-top:6px;">
            <span class="badge">
              <span class="dot" id="liveDot"></span>
              <span id="liveStatus">Idle</span>
            </span>

            <span class="djBadge" id="djName" style="margin-left:10px;">Auto DJ</span>

            <span style="margin-left:10px;" id="listenerText">Listeners: –</span>
          </div>
        </div>
      </div>

      <div class="vol">
        <span>Volume</span>
        <input id="vol" type="range" min="0" max="1" step="0.01" value="0.85" />
      </div>
    </div>
  </div>

  <!-- IN-PAGE PLAYER DRAWER (this is the ONE audio element we keep) -->
  <div id="playerDrawer" class="playerDrawer" hidden>
    <button id="closePlayer" type="button" aria-label="Close player">✕</button>

    <audio id="rpAudio" controls preload="none" playsinline>
      <source src="https://a5.asurahosting.com:7780/radio.mp3" type="audio/mpeg">
    </audio>
  </div>

  <!-- SCRIPTS -->
  <script src="/assets/player.js" defer></script>
  <script src="https://unpkg.com/swup@4" defer></script>

  <script>
    // --- Now Playing ribbon updater (safe with Swup swaps) ---
    async function updateNowPlaying() {
      try {
        const res = await fetch("https://a5.asurahosting.com/api/nowplaying/239", { cache: "no-store" });
        const data = await res.json();
        const np = data?.now_playing?.song;

        const el = document.getElementById("nowPlayingText"); // re-select every time
        if (el && np) el.textContent = `▶ Now Playing: ${np.artist} — ${np.title}`;
      } catch (e) {
        // don't spam console; just quietly fail
      }
    }

    updateNowPlaying();
    setInterval(updateNowPlaying, 15000);
  </script>

  <script>
    // --- schedule popup handler (needs re-binding after Swup content swap) ---
    function bindSchedulePopup() {
      const link = document.getElementById("openSchedule");
      if (!link) return;

      // prevent double-binding
      if (link.dataset.bound === "1") return;
      link.dataset.bound = "1";

      link.addEventListener("click", (e) => {
        e.preventDefault();
        window.open(
          link.href,
          "RadioPengSchedule",
          "width=1200,height=800,resizable=yes,scrollbars=yes"
        );
      });
    }

    function bindHomePlayButton() {
      const homePlay = document.getElementById("playBtnHome");
      const mainPlay = document.getElementById("playBtn");
      if (!homePlay || !mainPlay) return;

      if (homePlay.dataset.bound === "1") return;
      homePlay.dataset.bound = "1";

      homePlay.addEventListener("click", () => mainPlay.click());
    }

    function bindExperimentalMode() {
      const root = document.body;
      if (!root) return;

      root.classList.add("experimental-site");

      const params = new URLSearchParams(window.location.search);
      const mode = (params.get("mode") || "").toLowerCase();
      const night = (params.get("night") || "auto").toLowerCase();
      const hour = new Date().getHours();

      const autoNight = hour >= 23 || hour < 5;
      const autoBrutalist = hour >= 18 || hour < 7;

      const useNight = night === "1" || night === "true" || night === "on"
        ? true
        : night === "0" || night === "false" || night === "off"
          ? false
          : autoNight;

      const useBrutalist = mode === "brutalist"
        ? true
        : mode === "clean"
          ? false
          : autoBrutalist;

      root.classList.toggle("late-night-mode", useNight);
      root.classList.toggle("brutalist-mode", useBrutalist);

      const shapesWrap = document.getElementById("heroShapes");
      if (!shapesWrap || shapesWrap.dataset.seeded === "1") return;
      shapesWrap.dataset.seeded = "1";

      const shapeCount = 7;
      for (let i = 0; i < shapeCount; i++) {
        const node = document.createElement("span");
        node.className = "shape";

        const w = 42 + Math.round(Math.random() * 120);
        const h = 8 + Math.round(Math.random() * 36);
        const x = Math.round(Math.random() * 92);
        const y = Math.round(Math.random() * 90);
        const r = Math.round((Math.random() - 0.5) * 60);
        const hueA = 180 + Math.round(Math.random() * 130);
        const hueB = 250 + Math.round(Math.random() * 90);
        const opacity = (0.09 + Math.random() * 0.2).toFixed(2);

        node.style.width = `${w}px`;
        node.style.height = `${h}px`;
        node.style.left = `${x}%`;
        node.style.top = `${y}%`;
        node.style.transform = `rotate(${r}deg)`;
        node.style.setProperty("--shape-a", `hsla(${hueA}, 92%, 72%, ${opacity})`);
        node.style.setProperty("--shape-b", `hsla(${hueB}, 92%, 70%, ${opacity})`);

        shapesWrap.appendChild(node);
      }
    }
  </script>

  <script>
    // Swup init (kept outside player.js so the player remains stable)
    document.addEventListener("DOMContentLoaded", () => {
      if (typeof Swup === "undefined") return;

      const swup = new Swup({
        containers: ["#swup"],
        linkSelector: "a[href^='/']:not([href^='//']):not([href^='http']):not([data-no-swup])"
      });

      swup.hooks.on("content:replace", () => {
        window.scrollTo(0, 0);
        bindSchedulePopup();
        bindHomePlayButton();
        bindExperimentalMode();
        updateNowPlaying();
      });

      // first bind
      bindSchedulePopup();
      bindHomePlayButton();
      bindExperimentalMode();
    });
  </script>

  <!-- MIRROR NOW PLAYING + SHOW INTO SIDEBAR -->
  <script>
    (function () {
      const mainNP = document.getElementById("npText");
      const sideNP = document.getElementById("npTextSide");

      const mainShow = document.getElementById("npShow");
      const sideShow = document.getElementById("npShowSide");

      if (!mainNP || !sideNP) return;

      const sync = () => {
        sideNP.textContent = mainNP.textContent || "—";

        if (mainShow && sideShow) {
          const showTxt = (mainShow.textContent || "").trim();
          if (showTxt) {
            sideShow.textContent = showTxt;
            sideShow.classList.remove("hidden");
          } else {
            sideShow.textContent = "";
            sideShow.classList.add("hidden");
          }
        }
      };

      sync();
      setInterval(sync, 1000);
    })();
  </script>

  <script>
    (function footerToneByTime() {
      const footer = document.getElementById("siteFooter");
      if (!footer) return;

      const h = new Date().getHours();

      let vars;

      if (h >= 5 && h < 10) {
        vars = {
          "--f-bg-1": "rgba(18, 14, 24, 0.95)",
          "--f-bg-2": "rgba(10, 8, 14, 0.98)",
          "--f-accent": "rgba(220, 170, 110, 0.35)",
          "--f-text": "rgba(220, 210, 230, 0.70)",
          "--f-text-strong": "#f1eaff"
        };
      } else if (h >= 10 && h < 17) {
        vars = {
          "--f-bg-1": "rgba(18, 18, 22, 0.92)",
          "--f-bg-2": "rgba(10, 10, 14, 0.98)",
          "--f-accent": "rgba(140, 200, 210, 0.30)",
          "--f-text": "rgba(220, 220, 235, 0.68)",
          "--f-text-strong": "#f2f2ff"
        };
      } else if (h >= 17 && h < 21) {
        vars = {
          "--f-bg-1": "rgba(22, 12, 16, 0.95)",
          "--f-bg-2": "rgba(8, 5, 8, 0.98)",
          "--f-accent": "rgba(210, 90, 120, 0.32)",
          "--f-text": "rgba(235, 210, 220, 0.70)",
          "--f-text-strong": "#ffe9f3"
        };
      } else {
        vars = {
          "--f-bg-1": "rgba(8, 6, 12, 0.95)",
          "--f-bg-2": "rgba(4, 3, 6, 0.98)",
          "--f-accent": "rgba(160, 120, 200, 0.40)",
          "--f-text": "rgba(210, 200, 230, 0.70)",
          "--f-text-strong": "#e6ddff"
        };
      }

      for (const [k, v] of Object.entries(vars)) footer.style.setProperty(k, v);
    })();
  </script>

</body>
</html>