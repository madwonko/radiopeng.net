---
layout: layout-base.njk
title: Articles
permalink: /articles/index.html
---

<section class="hero">
  <h1>Articles</h1>
  <p>Reviews, dispatches, and occasional sonic conspiracy theories.</p>
</section>

<section class="card" style="margin-top:18px;">
  <div class="article-list">
    {% for post in collections.articles | reverse %}
      <a class="article" href="{{ post.url }}">
        <div class="kicker">{{ post.date | readableDate }}</div>
        <div class="name">{{ post.data.title }}</div>
        {% if post.data.description %}
          <div class="blurb">{{ post.data.description }}</div>
        {% endif %}
      </a>
    {% endfor %}
  </div>
</section>
