---
layout: layout-base.njk
title: Local Manager
permalink: /manage/index.html
---

<section class="hero">
  <h1>Local Manager</h1>
  <p>DJ management + article composer.</p>
</section>

<section class="card">
  <h2>Studio API Token</h2>
  <p class="meta">Used for image uploads and saving DJ data via the protected upload API.</p>
  <div class="pill-row">
    <input id="studioToken" type="password" placeholder="Studio API token" style="flex:1;min-width:260px;background:#00000040;color:#fff;border:1px solid #ffffff2e;border-radius:10px;padding:10px;" />
    <button class="btn" id="saveStudioToken">Save token</button>
  </div>
</section>

<section class="card" style="margin-top:14px;">
  <h2>DJ Manager</h2>
  <p class="meta">Edit DJs with a form and upload profile photos directly.</p>

  <div class="archive-control-grid">
    <label>
      <div class="meta">Select DJ</div>
      <select id="djSelect"></select>
    </label>
    <label>
      <div class="meta">Slug</div>
      <input id="djSlug" type="text" placeholder="night-operator" />
    </label>
    <label>
      <div class="meta">Name</div>
      <input id="djName" type="text" placeholder="Night Operator" />
    </label>
    <label>
      <div class="meta">Tagline</div>
      <input id="djTagline" type="text" placeholder="Ambient fog, tape hiss..." />
    </label>
  </div>

  <label style="display:block;margin-top:10px;">
    <div class="meta">Bio</div>
    <textarea id="djBio" style="width:100%;min-height:120px;background:#00000040;color:#fff;border:1px solid #ffffff2e;border-radius:10px;padding:10px;"></textarea>
  </label>

  <div class="archive-control-grid" style="margin-top:10px;">
    <label><div class="meta">Pronouns</div><input id="djPronouns" type="text" placeholder="they/them" /></label>
    <label><div class="meta">Location</div><input id="djLocation" type="text" placeholder="Remote" /></label>
    <label><div class="meta">Photo URL</div><input id="djPhoto" type="text" placeholder="/assets/uploads/djs/photo.jpg" /></label>
    <label><div class="meta">Active</div><select id="djActive"><option value="true">true</option><option value="false">false</option></select></label>
  </div>

  <label style="display:block;margin-top:10px;">
    <div class="meta">Upload DJ Photo</div>
    <input id="djPhotoFile" type="file" accept="image/*" />
  </label>

  <div class="pill-row" style="margin-top:10px;">
    <button class="btn" id="djNew">New DJ</button>
    <button class="btn" id="djUploadPhoto">Upload photo</button>
    <button class="btn" id="djSave">Save DJ</button>
  </div>

  <div id="djOut" class="meta" style="margin-top:8px;white-space:pre-wrap;background:#00000030;border:1px solid #ffffff22;border-radius:10px;padding:10px;min-height:48px;">Ready.</div>
</section>

<section class="card" style="margin-top:14px;">
  <h2>Article Composer</h2>

  <div class="archive-control-grid">
    <label><div class="meta">Title</div><input id="articleTitle" type="text" /></label>
    <label><div class="meta">Date</div><input id="articleDate" type="date" /></label>
    <label><div class="meta">Image URL</div><input id="articleImage" type="text" placeholder="/assets/uploads/articles/..." /></label>
    <label><div class="meta">Upload Article Image</div><input id="articleImageFile" type="file" accept="image/*" /></label>
  </div>

  <div class="pill-row" style="margin-top:10px;">
    <button class="btn" id="articleUploadImage">Upload image</button>
  </div>

  <label style="display:block;margin-top:10px;"><div class="meta">Brief description</div><textarea id="articleDescription" style="width:100%;min-height:84px;background:#00000040;color:#fff;border:1px solid #ffffff2e;border-radius:10px;padding:10px;"></textarea></label>
  <label style="display:block;margin-top:10px;"><div class="meta">Article body (Markdown)</div><textarea id="articleBody" style="width:100%;min-height:220px;background:#00000040;color:#fff;border:1px solid #ffffff2e;border-radius:10px;padding:10px;"></textarea></label>

  <div class="pill-row" style="margin-top:10px;">
    <button class="btn" id="articleGenerate">Generate markdown</button>
    <button class="btn" id="articleDownload">Download .md</button>
  </div>

  <div id="articleOut" class="meta" style="margin-top:8px;white-space:pre-wrap;background:#00000030;border:1px solid #ffffff22;border-radius:10px;padding:10px;min-height:48px;">Fill fields and generate file.</div>
  <label style="display:block;margin-top:10px;"><div class="meta">Generated markdown</div><textarea id="articleMarkdown" style="width:100%;min-height:240px;background:#00000040;color:#fff;border:1px solid #ffffff2e;border-radius:10px;padding:10px;"></textarea></label>
</section>

<script>
(() => {
  const byId = (id) => document.getElementById(id);
  const djOut = byId('djOut');
  const articleOut = byId('articleOut');
  let djsData = { items: [] };

  function slugify(s) {
    return String(s || '').normalize('NFKD').replace(/[\u0300-\u036f]/g, '').toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-+|-+$/g,'').replace(/-{2,}/g,'-');
  }

  function escYaml(str) {
    return String(str || '').replace(/"/g, '\\"');
  }

  function token() {
    return byId('studioToken').value || localStorage.getItem('studioUploadToken') || '';
  }

  async function loadDjs() {
    const res = await fetch('/manage-data/djs.json', { cache: 'no-store' });
    djsData = await res.json();
    if (!Array.isArray(djsData.items)) djsData.items = [];
    renderDjSelect();
  }

  function renderDjSelect(selected='') {
    const sel = byId('djSelect');
    sel.innerHTML = '';
    const opts = [{ slug: '', name: '— Select DJ —' }, ...djsData.items];
    for (const dj of opts) {
      const o = document.createElement('option');
      o.value = dj.slug || '';
      o.textContent = dj.name ? `${dj.name} (${dj.slug})` : '— Select DJ —';
      if (selected && selected === o.value) o.selected = true;
      sel.appendChild(o);
    }
  }

  function fillDjForm(dj) {
    byId('djSlug').value = dj?.slug || '';
    byId('djName').value = dj?.name || '';
    byId('djTagline').value = dj?.tagline || '';
    byId('djBio').value = dj?.bio || '';
    byId('djPronouns').value = dj?.pronouns || '';
    byId('djLocation').value = dj?.location || '';
    byId('djPhoto').value = dj?.photo || '';
    byId('djActive').value = String(dj?.active !== false);
  }

  async function uploadImage(file, folder, nameHint) {
    const t = token();
    if (!t) throw new Error('Missing Studio API token.');
    if (!file) throw new Error('No file selected.');

    const fd = new FormData();
    fd.append('image', file);
    fd.append('folder', folder);
    fd.append('name', nameHint || 'upload');
    fd.append('rebuild', 'true');

    const res = await fetch('/studio/api/upload-image', {
      method: 'POST',
      headers: { 'x-studio-token': t },
      body: fd
    });
    const data = await res.json();
    if (!res.ok || !data.ok) throw new Error(data.error || `Upload failed (${res.status})`);
    return data.url;
  }

  async function saveDjsRemote() {
    const t = token();
    if (!t) throw new Error('Missing Studio API token.');
    const res = await fetch('/studio/api/save-djs', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-studio-token': t },
      body: JSON.stringify({ items: djsData.items })
    });
    const data = await res.json();
    if (!res.ok || !data.ok) throw new Error(data.error || `Save failed (${res.status})`);
    return data;
  }

  function buildArticleMarkdown() {
    const title = byId('articleTitle').value.trim();
    const date = byId('articleDate').value.trim();
    const image = byId('articleImage').value.trim();
    const description = byId('articleDescription').value.trim();
    const body = byId('articleBody').value;

    if (!title) throw new Error('Title is required.');
    if (!date) throw new Error('Date is required.');
    if (!description) throw new Error('Brief description is required.');
    if (!body.trim()) throw new Error('Article body is required.');

    const lines = [
      '---',
      `title: "${escYaml(title)}"`,
      `description: "${escYaml(description)}"`,
      `date: ${date}`,
      'tags: [articles]',
      'layout: layout-article.njk',
    ];
    if (image) lines.push(`image: "${escYaml(image)}"`);
    lines.push('---', '', body.trim(), '');

    return { markdown: lines.join('\n'), filename: `${date}-${slugify(title) || 'article'}.md` };
  }

  byId('saveStudioToken').addEventListener('click', () => {
    localStorage.setItem('studioUploadToken', byId('studioToken').value || '');
    djOut.textContent = 'Token saved in this browser.';
  });

  byId('djSelect').addEventListener('change', (e) => {
    const dj = djsData.items.find(x => x.slug === e.target.value);
    fillDjForm(dj || {});
  });

  byId('djNew').addEventListener('click', () => {
    byId('djSelect').value = '';
    fillDjForm({ active: true });
    djOut.textContent = 'New DJ form ready.';
  });

  byId('djUploadPhoto').addEventListener('click', async () => {
    try {
      const file = byId('djPhotoFile').files[0];
      const nameHint = byId('djName').value || byId('djSlug').value || 'dj-photo';
      const url = await uploadImage(file, 'djs', nameHint);
      byId('djPhoto').value = url;
      djOut.textContent = `Photo uploaded: ${url}`;
    } catch (e) {
      djOut.textContent = `Upload error: ${e.message}`;
    }
  });

  byId('djSave').addEventListener('click', async () => {
    try {
      const slug = slugify(byId('djSlug').value || byId('djName').value);
      if (!slug) throw new Error('DJ slug or name required.');

      const item = {
        slug,
        name: byId('djName').value.trim(),
        tagline: byId('djTagline').value.trim(),
        bio: byId('djBio').value.trim(),
        photo: byId('djPhoto').value.trim(),
        pronouns: byId('djPronouns').value.trim(),
        location: byId('djLocation').value.trim(),
        active: byId('djActive').value === 'true',
        social: []
      };

      const idx = djsData.items.findIndex(x => x.slug === slug);
      if (idx >= 0) djsData.items[idx] = { ...djsData.items[idx], ...item };
      else djsData.items.push(item);

      await saveDjsRemote();
      renderDjSelect(slug);
      djOut.textContent = `Saved DJ '${item.name || slug}' and rebuilt site.`;
    } catch (e) {
      djOut.textContent = `Save error: ${e.message}`;
    }
  });

  byId('articleUploadImage').addEventListener('click', async () => {
    try {
      const file = byId('articleImageFile').files[0];
      const hint = byId('articleTitle').value || 'article-image';
      const url = await uploadImage(file, 'articles', hint);
      byId('articleImage').value = url;
      articleOut.textContent = `Image uploaded: ${url}`;
    } catch (e) {
      articleOut.textContent = `Image upload error: ${e.message}`;
    }
  });

  byId('articleGenerate').addEventListener('click', () => {
    try {
      const { markdown, filename } = buildArticleMarkdown();
      byId('articleMarkdown').value = markdown;
      articleOut.textContent = `Generated ${filename}`;
    } catch (e) {
      articleOut.textContent = `Error: ${e.message}`;
    }
  });

  byId('articleDownload').addEventListener('click', () => {
    try {
      const { markdown, filename } = buildArticleMarkdown();
      const blob = new Blob([markdown], { type: 'text/markdown;charset=utf-8' });
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = filename;
      a.click();
      setTimeout(() => URL.revokeObjectURL(a.href), 1000);
      articleOut.textContent = `Downloaded ${filename}`;
    } catch (e) {
      articleOut.textContent = `Error: ${e.message}`;
    }
  });

  const d = new Date();
  byId('articleDate').value = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
  const saved = localStorage.getItem('studioUploadToken') || '';
  if (saved) byId('studioToken').value = saved;

  loadDjs();
})();
</script>
