---
layout: layout-base.njk
title: Local Manager
permalink: /manage/index.html
---

<section class="hero">
  <h1>Local Manager</h1>
  <p>DJ management + article composer.</p>
</section>

<section class="card">
  <h2>Studio API Token</h2>
  <p class="meta">Used for image uploads and saving DJ data via the protected upload API.</p>
  <div class="pill-row">
    <input id="studioToken" type="password" placeholder="Studio API token" style="flex:1;min-width:260px;background:#00000040;color:#fff;border:1px solid #ffffff2e;border-radius:10px;padding:10px;" />
    <button class="btn" id="saveStudioToken">Save token</button>
  </div>
  <div id="tokenStatus" class="meta" style="margin-top:8px;">Token not loaded.</div>
</section>

<section class="card" style="margin-top:14px;">
  <h2>DJ Manager</h2>
  <p class="meta">Edit DJs with a form and upload profile photos directly.</p>

  <div class="archive-control-grid">
    <label>
      <div class="meta">Select DJ</div>
      <select id="djSelect"></select>
    </label>
    <label>
      <div class="meta">Slug</div>
      <input id="djSlug" type="text" placeholder="night-operator" />
    </label>
    <label>
      <div class="meta">Name</div>
      <input id="djName" type="text" placeholder="Night Operator" />
    </label>
    <label>
      <div class="meta">Tagline</div>
      <input id="djTagline" type="text" placeholder="Ambient fog, tape hiss..." />
    </label>
  </div>

  <label style="display:block;margin-top:10px;">
    <div class="meta">Bio</div>
    <textarea id="djBio" style="width:100%;min-height:120px;background:#00000040;color:#fff;border:1px solid #ffffff2e;border-radius:10px;padding:10px;"></textarea>
  </label>

  <div class="archive-control-grid" style="margin-top:10px;">
    <label><div class="meta">Pronouns</div><input id="djPronouns" type="text" placeholder="they/them" /></label>
    <label><div class="meta">Location</div><input id="djLocation" type="text" placeholder="Remote" /></label>
    <label><div class="meta">Photo URL</div><input id="djPhoto" type="text" placeholder="/assets/uploads/djs/photo.jpg" /></label>
    <label><div class="meta">Active</div><select id="djActive"><option value="true">true</option><option value="false">false</option></select></label>
  </div>

  <label style="display:block;margin-top:10px;">
    <div class="meta">Upload DJ Photo</div>
    <input id="djPhotoFile" type="file" accept="image/*" />
  </label>

  <div class="pill-row" style="margin-top:10px;">
    <button class="btn" id="djNew">New DJ</button>
    <button class="btn" id="djUploadPhoto">Upload photo</button>
    <button class="btn" id="djSave">Save DJ</button>
  </div>

  <div id="djOut" class="meta" style="margin-top:8px;white-space:pre-wrap;background:#00000030;border:1px solid #ffffff22;border-radius:10px;padding:10px;min-height:48px;">Ready.</div>
</section>


<section class="card" style="margin-top:14px;">
  <h2>Shows Manager</h2>
  <p class="meta">Create/update show cards and upload show artwork.</p>

  <div class="archive-control-grid">
    <label><div class="meta">Select Show</div><select id="showSelect"></select></label>
    <label><div class="meta">Slug</div><input id="showSlug" type="text" placeholder="wonko-odd-hours" /></label>
    <label><div class="meta">Title</div><input id="showTitle" type="text" placeholder="Wonko’s Odd Hours" /></label>
    <label><div class="meta">DJ Slug</div><input id="showDjSlug" type="text" placeholder="madwonko" /></label>
  </div>

  <label style="display:block;margin-top:10px;"><div class="meta">Description</div><textarea id="showDescription" style="width:100%;min-height:100px;background:#00000040;color:#fff;border:1px solid #ffffff2e;border-radius:10px;padding:10px;"></textarea></label>

  <div class="archive-control-grid" style="margin-top:10px;">
    <label><div class="meta">Genre</div><input id="showGenre" type="text" placeholder="Ambient / Downtempo" /></label>
    <label><div class="meta">Schedule</div><input id="showSchedule" type="text" placeholder="Sundays 11:00 PM–1:00 AM ET" /></label>
    <label><div class="meta">Artwork URL</div><input id="showArtwork" type="text" placeholder="/assets/uploads/shows/art.jpg" /></label>
    <label><div class="meta">Active</div><select id="showActive"><option value="true">true</option><option value="false">false</option></select></label>
  </div>

  <label style="display:block;margin-top:10px;"><div class="meta">Upload Show Artwork</div><input id="showArtworkFile" type="file" accept="image/*" /></label>

  <div class="pill-row" style="margin-top:10px;">
    <button class="btn" id="showNew">New Show</button>
    <button class="btn" id="showUploadArtwork">Upload artwork</button>
    <button class="btn" id="showSave">Save Show</button>
  </div>

  <div id="showOut" class="meta" style="margin-top:8px;white-space:pre-wrap;background:#00000030;border:1px solid #ffffff22;border-radius:10px;padding:10px;min-height:48px;">Ready.</div>
</section>


<section class="card" style="margin-top:14px;">
  <h2>Schedule Manager</h2>
  <p class="meta">Manage weekly schedule slots and assign them to shows.</p>

  <div class="archive-control-grid">
    <label><div class="meta">Select Slot</div><select id="scheduleSelect"></select></label>
    <label><div class="meta">Day</div>
      <select id="slotDay">
        <option>Sun</option><option>Mon</option><option>Tue</option><option>Wed</option><option>Thu</option><option>Fri</option><option>Sat</option>
      </select>
    </label>
    <label><div class="meta">Start (HH:MM)</div><input id="slotStart" type="text" placeholder="20:00" /></label>
    <label><div class="meta">End (HH:MM)</div><input id="slotEnd" type="text" placeholder="22:00" /></label>
  </div>

  <div class="archive-control-grid" style="margin-top:10px;">
    <label><div class="meta">Show Slug</div><select id="slotShowSlug"></select></label>
    <label><div class="meta">Show Title Override (optional)</div><input id="slotShowTitle" type="text" placeholder="Wonko’s Odd Hours" /></label>
    <label><div class="meta">Timezone</div><input id="scheduleTimezone" type="text" placeholder="America/New_York" /></label>
    <label><div class="meta">Row Number</div><input id="slotIndex" type="text" readonly /></label>
  </div>

  <div class="pill-row" style="margin-top:10px;">
    <button class="btn" id="slotNew">New Slot</button>
    <button class="btn" id="slotSave">Save Slot</button>
    <button class="btn" id="slotDelete">Delete Slot</button>
    <button class="btn" id="scheduleSaveAll">Save Schedule</button>
  </div>

  <div id="scheduleOut" class="meta" style="margin-top:8px;white-space:pre-wrap;background:#00000030;border:1px solid #ffffff22;border-radius:10px;padding:10px;min-height:48px;">Ready.</div>
</section>

<section class="card" style="margin-top:14px;">
  <h2>Article Composer</h2>

  <div class="archive-control-grid">
    <label><div class="meta">Title</div><input id="articleTitle" type="text" /></label>
    <label><div class="meta">Date</div><input id="articleDate" type="date" /></label>
    <label><div class="meta">Image URL</div><input id="articleImage" type="text" placeholder="/assets/uploads/articles/..." /></label>
    <label><div class="meta">Upload Article Image</div><input id="articleImageFile" type="file" accept="image/*" /></label>
  </div>

  <div class="pill-row" style="margin-top:10px;">
    <button class="btn" id="articleUploadImage">Upload image</button>
  </div>

  <label style="display:block;margin-top:10px;"><div class="meta">Brief description</div><textarea id="articleDescription" style="width:100%;min-height:84px;background:#00000040;color:#fff;border:1px solid #ffffff2e;border-radius:10px;padding:10px;"></textarea></label>
  <label style="display:block;margin-top:10px;"><div class="meta">Article body (Markdown)</div><textarea id="articleBody" style="width:100%;min-height:220px;background:#00000040;color:#fff;border:1px solid #ffffff2e;border-radius:10px;padding:10px;"></textarea></label>

  <div class="pill-row" style="margin-top:10px;">
    <button class="btn" id="articleGenerate">Generate markdown</button>
    <button class="btn" id="articleDownload">Download .md</button>
    <button class="btn" id="articlePublish">Publish article</button>
  </div>

  <div id="articleOut" class="meta" style="margin-top:8px;white-space:pre-wrap;background:#00000030;border:1px solid #ffffff22;border-radius:10px;padding:10px;min-height:48px;">Fill fields and generate file.</div>
  <label style="display:block;margin-top:10px;"><div class="meta">Generated markdown</div><textarea id="articleMarkdown" style="width:100%;min-height:240px;background:#00000040;color:#fff;border:1px solid #ffffff2e;border-radius:10px;padding:10px;"></textarea></label>
</section>

<script>
(() => {
  const byId = (id) => document.getElementById(id);
  const djOut = byId('djOut');
  const tokenStatus = byId('tokenStatus');
  let memoryToken = '';

  function safeGetToken() {
    if (memoryToken) return memoryToken;
    try {
      return localStorage.getItem('studioUploadToken') || '';
    } catch (_) {
      return '';
    }
  }

  function safeSetToken(v) {
    memoryToken = v || '';
    try {
      localStorage.setItem('studioUploadToken', memoryToken);
      return 'saved';
    } catch (_) {
      return 'memory';
    }
  }

  function refreshTokenStatus() {
    const v = byId('studioToken')?.value || safeGetToken();
    if (!tokenStatus) return;
    tokenStatus.textContent = v ? 'Token loaded.' : 'Token not loaded.';
  }

  const articleOut = byId('articleOut');
  let djsData = { items: [] };
  let showsData = { items: [] };
  const showOut = byId('showOut');
  const scheduleOut = byId('scheduleOut');
  let scheduleData = { timezone: 'America/New_York', items: [] };

  function slugify(s) {
    return String(s || '').normalize('NFKD').replace(/[\u0300-\u036f]/g, '').toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-+|-+$/g,'').replace(/-{2,}/g,'-');
  }

  function escYaml(str) {
    return String(str || '').replace(/"/g, '\\"');
  }

  function token() {
    return byId('studioToken').value || safeGetToken() || '';
  }

  async function loadShows() {
    const res = await fetch('/manage-data/shows.json', { cache: 'no-store' });
    showsData = await res.json();
    if (!Array.isArray(showsData.items)) showsData.items = [];
    renderShowSelect();
  }

  async function loadSchedule() {
    const res = await fetch('/manage-data/schedule.json', { cache: 'no-store' });
    scheduleData = await res.json();
    if (!Array.isArray(scheduleData.items)) scheduleData.items = [];
    if (!scheduleData.timezone) scheduleData.timezone = 'America/New_York';
    byId('scheduleTimezone').value = scheduleData.timezone;
    renderScheduleSelect();
    renderShowSlugOptions();
  }

  async function loadDjs() {
    const res = await fetch('/manage-data/djs.json', { cache: 'no-store' });
    djsData = await res.json();
    if (!Array.isArray(djsData.items)) djsData.items = [];
    renderDjSelect();
  }

  function renderDjSelect(selected='') {
    const sel = byId('djSelect');
    sel.innerHTML = '';
    const opts = [{ slug: '', name: '— Select DJ —' }, ...djsData.items];
    for (const dj of opts) {
      const o = document.createElement('option');
      o.value = dj.slug || '';
      o.textContent = dj.name ? `${dj.name} (${dj.slug})` : '— Select DJ —';
      if (selected && selected === o.value) o.selected = true;
      sel.appendChild(o);
    }
  }

  function renderShowSlugOptions(selected='') {
    const sel = byId('slotShowSlug');
    if (!sel) return;
    const cur = selected || sel.value || '';
    sel.innerHTML = '';
    const o0 = document.createElement('option'); o0.value=''; o0.textContent='— Select show —'; sel.appendChild(o0);
    for (const sh of showsData.items) {
      const o = document.createElement('option');
      o.value = sh.slug || '';
      o.textContent = sh.title ? `${sh.title} (${sh.slug})` : (sh.slug || 'show');
      if (cur && o.value === cur) o.selected = true;
      sel.appendChild(o);
    }
  }

  function renderScheduleSelect(selected='') {
    const sel = byId('scheduleSelect');
    if (!sel) return;
    sel.innerHTML = '';
    const o0 = document.createElement('option'); o0.value=''; o0.textContent='— Select Slot —'; sel.appendChild(o0);
    scheduleData.items.forEach((row, i) => {
      const o = document.createElement('option');
      o.value = String(i);
      o.textContent = `${row.days || '?'} ${row.start || '--:--'}-${row.end || '--:--'} · ${row.showSlug || row.show || ''}`;
      if (selected !== '' && String(selected) === String(i)) o.selected = true;
      sel.appendChild(o);
    });
  }

  function fillScheduleForm(row, idx='') {
    byId('slotIndex').value = idx === '' ? '' : String(idx);
    byId('slotDay').value = row?.days || 'Mon';
    byId('slotStart').value = row?.start || '';
    byId('slotEnd').value = row?.end || '';
    byId('slotShowSlug').value = row?.showSlug || '';
    byId('slotShowTitle').value = row?.show || '';
  }

  function renderShowSelect(selected='') {
    const sel = byId('showSelect');
    if (!sel) return;
    sel.innerHTML = "";
    const opts = [{ slug: '', title: '— Select Show —' }, ...showsData.items];
    for (const sh of opts) {
      const o = document.createElement('option');
      o.value = sh.slug || '';
      o.textContent = sh.title ? `${sh.title} (${sh.slug})` : '— Select Show —';
      if (selected && selected === o.value) o.selected = true;
      sel.appendChild(o);
    }
  }

  function fillShowForm(sh) {
    byId('showSlug').value = sh?.slug || '';
    byId('showTitle').value = sh?.title || '';
    byId('showDjSlug').value = sh?.djSlug || '';
    byId('showDescription').value = sh?.description || '';
    byId('showGenre').value = sh?.genre || '';
    byId('showSchedule').value = sh?.schedule || '';
    byId('showArtwork').value = sh?.artwork || '';
    byId('showActive').value = String(sh?.active !== false);
  }

  function fillDjForm(dj) {
    byId('djSlug').value = dj?.slug || '';
    byId('djName').value = dj?.name || '';
    byId('djTagline').value = dj?.tagline || '';
    byId('djBio').value = dj?.bio || '';
    byId('djPronouns').value = dj?.pronouns || '';
    byId('djLocation').value = dj?.location || '';
    byId('djPhoto').value = dj?.photo || '';
    byId('djActive').value = String(dj?.active !== false);
  }

  async function uploadImage(file, folder, nameHint) {
    const t = token();
    if (!t) throw new Error('Missing Studio API token.');
    if (!file) throw new Error('No file selected.');

    const fd = new FormData();
    fd.append('image', file);
    fd.append('folder', folder);
    fd.append('name', nameHint || 'upload');
    fd.append('rebuild', 'true');

    const res = await fetch('/studio/api/upload-image', {
      method: 'POST',
      headers: { 'x-studio-token': t },
      body: fd
    });
    const data = await res.json();
    if (!res.ok || !data.ok) throw new Error(data.error || `Upload failed (${res.status})`);
    return data.url;
  }

  async function saveShowsRemote() {
    const t = token();
    if (!t) throw new Error('Missing Studio API token.');
    const res = await fetch('/studio/api/save-shows', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-studio-token': t },
      body: JSON.stringify({ items: showsData.items })
    });
    const data = await res.json();
    if (!res.ok || !data.ok) throw new Error(data.error || `Save failed (${res.status})`);
    return data;
  }

  async function saveScheduleRemote() {
    const t = token();
    if (!t) throw new Error('Missing Studio API token.');
    const payload = { timezone: byId('scheduleTimezone').value.trim() || 'America/New_York', items: scheduleData.items };
    const res = await fetch('/studio/api/save-schedule', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-studio-token': t },
      body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (!res.ok || !data.ok) throw new Error(data.error || `Save failed (${res.status})`);
    return data;
  }

  async function saveDjsRemote() {
    const t = token();
    if (!t) throw new Error('Missing Studio API token.');
    const res = await fetch('/studio/api/save-djs', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-studio-token': t },
      body: JSON.stringify({ items: djsData.items })
    });
    const data = await res.json();
    if (!res.ok || !data.ok) throw new Error(data.error || `Save failed (${res.status})`);
    return data;
  }

  async function saveArticleRemote() {
    const t = token();
    if (!t) throw new Error('Missing Studio API token.');

    const payload = {
      title: byId('articleTitle').value.trim(),
      date: byId('articleDate').value.trim(),
      image: byId('articleImage').value.trim(),
      description: byId('articleDescription').value.trim(),
      body: byId('articleBody').value.trim(),
    };

    const res = await fetch('/studio/api/save-article', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-studio-token': t },
      body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (!res.ok || !data.ok) throw new Error(data.error || `Publish failed (${res.status})`);
    return data;
  }

  function buildArticleMarkdown() {
    const title = byId('articleTitle').value.trim();
    const date = byId('articleDate').value.trim();
    const image = byId('articleImage').value.trim();
    const description = byId('articleDescription').value.trim();
    const body = byId('articleBody').value;

    if (!title) throw new Error('Title is required.');
    if (!date) throw new Error('Date is required.');
    if (!description) throw new Error('Brief description is required.');
    if (!body.trim()) throw new Error('Article body is required.');

    const lines = [
      '---',
      `title: "${escYaml(title)}"`,
      `description: "${escYaml(description)}"`,
      `date: ${date}`,
      'tags: [articles]',
      'layout: layout-article.njk',
    ];
    if (image) lines.push(`image: "${escYaml(image)}"`);
    lines.push('---', '', body.trim(), '');

    return { markdown: lines.join('\n'), filename: `${date}-${slugify(title) || 'article'}.md` };
  }

  byId('saveStudioToken').addEventListener('click', () => {
    const mode = safeSetToken(byId('studioToken').value || '');
    refreshTokenStatus();
    djOut.textContent = mode === 'saved'
      ? 'Token saved in this browser.'
      : 'Token stored for this page only (browser blocks local storage).';
  });

  byId('djSelect').addEventListener('change', (e) => {
    const dj = djsData.items.find(x => x.slug === e.target.value);
    fillDjForm(dj || {});
  });

  byId('djNew').addEventListener('click', () => {
    byId('djSelect').value = '';
    fillDjForm({ active: true });
    djOut.textContent = 'New DJ form ready.';
  });

  byId('djUploadPhoto').addEventListener('click', async () => {
    try {
      const file = byId('djPhotoFile').files[0];
      const nameHint = byId('djName').value || byId('djSlug').value || 'dj-photo';
      const url = await uploadImage(file, 'djs', nameHint);
      byId('djPhoto').value = url;
      djOut.textContent = `Photo uploaded: ${url}`;
    } catch (e) {
      djOut.textContent = `Upload error: ${e.message}`;
    }
  });

  byId('djSave').addEventListener('click', async () => {
    try {
      const slug = slugify(byId('djSlug').value || byId('djName').value);
      if (!slug) throw new Error('DJ slug or name required.');

      const item = {
        slug,
        name: byId('djName').value.trim(),
        tagline: byId('djTagline').value.trim(),
        bio: byId('djBio').value.trim(),
        photo: byId('djPhoto').value.trim(),
        pronouns: byId('djPronouns').value.trim(),
        location: byId('djLocation').value.trim(),
        active: byId('djActive').value === 'true',
        social: []
      };

      const idx = djsData.items.findIndex(x => x.slug === slug);
      if (idx >= 0) djsData.items[idx] = { ...djsData.items[idx], ...item };
      else djsData.items.push(item);

      await saveDjsRemote();
      renderDjSelect(slug);
      djOut.textContent = `Saved DJ '${item.name || slug}' and rebuilt site.`;
    } catch (e) {
      djOut.textContent = `Save error: ${e.message}`;
    }
  });

  byId('showSelect').addEventListener('change', (e) => {
    const sh = showsData.items.find(x => x.slug === e.target.value);
    fillShowForm(sh || {});
  });

  byId('showNew').addEventListener('click', () => {
    byId('showSelect').value = '';
    fillShowForm({ active: true });
    showOut.textContent = 'New show form ready.';
  });

  byId('showUploadArtwork').addEventListener('click', async () => {
    try {
      const file = byId('showArtworkFile').files[0];
      const nameHint = byId('showTitle').value || byId('showSlug').value || 'show-artwork';
      const url = await uploadImage(file, 'shows', nameHint);
      byId('showArtwork').value = url;
      showOut.textContent = `Artwork uploaded: ${url}`;
    } catch (e) {
      showOut.textContent = `Upload error: ${e.message}`;
    }
  });

  byId('showSave').addEventListener('click', async () => {
    try {
      const slug = slugify(byId('showSlug').value || byId('showTitle').value);
      if (!slug) throw new Error('Show slug or title required.');
      const item = {
        slug,
        title: byId('showTitle').value.trim(),
        description: byId('showDescription').value.trim(),
        djSlug: byId('showDjSlug').value.trim(),
        genre: byId('showGenre').value.trim(),
        schedule: byId('showSchedule').value.trim(),
        artwork: byId('showArtwork').value.trim(),
        active: byId('showActive').value === 'true',
      };

      const idx = showsData.items.findIndex(x => x.slug === slug);
      if (idx >= 0) showsData.items[idx] = { ...showsData.items[idx], ...item };
      else showsData.items.push(item);

      await saveShowsRemote();
      renderShowSelect(slug);
      renderShowSlugOptions();
      showOut.textContent = `Saved show '${item.title || slug}' and rebuilt site.`;
    } catch (e) {
      showOut.textContent = `Save error: ${e.message}`;
    }
  });


  byId('scheduleSelect').addEventListener('change', (e) => {
    const idx = e.target.value;
    if (idx === '') return fillScheduleForm({}, '');
    fillScheduleForm(scheduleData.items[Number(idx)] || {}, idx);
  });

  byId('slotNew').addEventListener('click', () => {
    byId('scheduleSelect').value = '';
    fillScheduleForm({ days: 'Mon', start: '', end: '', showSlug: '', show: '' }, '');
    scheduleOut.textContent = 'New slot form ready.';
  });

  byId('slotSave').addEventListener('click', () => {
    try {
      const row = {
        days: byId('slotDay').value,
        start: byId('slotStart').value.trim(),
        end: byId('slotEnd').value.trim(),
        showSlug: byId('slotShowSlug').value.trim(),
      };
      const showTitle = byId('slotShowTitle').value.trim();
      if (showTitle) row.show = showTitle;

      const i = byId('slotIndex').value;
      if (i === '') scheduleData.items.push(row);
      else scheduleData.items[Number(i)] = row;

      scheduleData.items.sort((a,b) => {
        const order = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
        const da = order.indexOf(a.days); const db = order.indexOf(b.days);
        if (da !== db) return da-db;
        return String(a.start||'').localeCompare(String(b.start||''));
      });

      renderScheduleSelect();
      scheduleOut.textContent = 'Slot saved locally. Click Save Schedule to publish.';
      byId('slotIndex').value = '';
    } catch (e) {
      scheduleOut.textContent = `Save error: ${e.message}`;
    }
  });

  byId('slotDelete').addEventListener('click', () => {
    const i = byId('slotIndex').value;
    if (i === '') return (scheduleOut.textContent = 'No slot selected.');
    scheduleData.items.splice(Number(i), 1);
    renderScheduleSelect();
    fillScheduleForm({}, '');
    scheduleOut.textContent = 'Slot deleted locally. Click Save Schedule to publish.';
  });

  byId('scheduleSaveAll').addEventListener('click', async () => {
    try {
      await saveScheduleRemote();
      scheduleOut.textContent = 'Schedule saved and site rebuilt.';
    } catch (e) {
      scheduleOut.textContent = `Publish error: ${e.message}`;
    }
  });

  byId('articleUploadImage').addEventListener('click', async () => {
    try {
      const file = byId('articleImageFile').files[0];
      const hint = byId('articleTitle').value || 'article-image';
      const url = await uploadImage(file, 'articles', hint);
      byId('articleImage').value = url;
      articleOut.textContent = `Image uploaded: ${url}`;
    } catch (e) {
      articleOut.textContent = `Image upload error: ${e.message}`;
    }
  });

  byId('articleGenerate').addEventListener('click', () => {
    try {
      const { markdown, filename } = buildArticleMarkdown();
      byId('articleMarkdown').value = markdown;
      articleOut.textContent = `Generated ${filename}`;
    } catch (e) {
      articleOut.textContent = `Error: ${e.message}`;
    }
  });

  byId('articleDownload').addEventListener('click', () => {
    try {
      const { markdown, filename } = buildArticleMarkdown();
      const blob = new Blob([markdown], { type: 'text/markdown;charset=utf-8' });
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = filename;
      a.click();
      setTimeout(() => URL.revokeObjectURL(a.href), 1000);
      articleOut.textContent = `Downloaded ${filename}`;
    } catch (e) {
      articleOut.textContent = `Error: ${e.message}`;
    }
  });

  const d = new Date();
  byId('articleDate').value = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
  const saved = safeGetToken();
  if (saved) byId('studioToken').value = saved;
  refreshTokenStatus();

  byId('studioToken')?.addEventListener('input', refreshTokenStatus);

  loadDjs();
  loadShows();
  loadSchedule();
})();
</script>
